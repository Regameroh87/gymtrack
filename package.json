{
  "name": "gymtrack-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/mobile",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "patch-package",
    "mobile": "npm --workspace gymtrack run start",
    "mobile:android": "npm --workspace gymtrack run android",
    "mobile:ios": "npm --workspace gymtrack run ios"
  },
  "devDependencies": {
    "patch-package": "^8.0.1"
  }
}
