# apps/web es una isla independiente (fuera de los workspaces del monorepo, con su
# propio lockfile). install-links hace que la dependencia file: a @gymtrack/core se
# instale como copia autocontenida con sus propias deps, en vez de un junction al
# paquete del workspace —lo que arrastraría la raíz del monorepo dentro de node_modules.
# Tradeoff: si editás packages/core, reinstalá en apps/web para reflejar el cambio.
install-links=true
