# Supabase (clave publishable / anon — segura para el cliente)
# La misma clave habilita la sesión por cookies (SSR) del panel autenticado vía
# @supabase/ssr; no se requiere service role para el login.
NEXT_PUBLIC_SUPABASE_URL=https://claoplxdhdxoixfdsatz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Cloudinary (para construir URLs de logos de gym a partir del public_id)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=ddupuyeko

# Dominio raíz del sitio (sin protocolo). En local: localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=gymtrack.ar

# URL base pública (con protocolo) para canonical/OG/sitemap
NEXT_PUBLIC_SITE_URL=https://gymtrack.ar

# Dominio del panel autenticado de Next.js — destino del CTA "Ingresar".
# El panel (login + /admin + /platform) se sirve en el subdominio app.; el
# middleware lo trata como host reservado (no lo reescribe como gym). En local:
# app.localhost:3000.
NEXT_PUBLIC_APP_URL=https://app.gymtrack.ar
